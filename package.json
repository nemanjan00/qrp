{
	"name": "@nemanjan00/qrp",
	"version": "0.4.0",
	"description": "A data-first, declarative, low-overhead framework for dashboards. Zero RUNTIME dependencies, zero build step — the devDependencies below are only for tests, lint, and git hooks.",
	"type": "module",
	"license": "MIT",
	"exports": {
		".": {
			"types": "./qrp/index.d.ts",
			"default": "./dist/qrp.js"
		},
		"./html": {
			"types": "./html/index.d.ts",
			"default": "./dist/html.js"
		},
		"./forms": {
			"types": "./forms/index.d.ts",
			"default": "./dist/forms.js"
		},
		"./table": {
			"types": "./table/index.d.ts",
			"default": "./dist/table.js"
		},
		"./collection": {
			"types": "./collection/index.d.ts",
			"default": "./dist/collection.js"
		},
		"./http": {
			"types": "./http/index.d.ts",
			"default": "./dist/http.js"
		},
		"./events": {
			"types": "./events/index.d.ts",
			"default": "./dist/events.js"
		},
		"./toasts": {
			"types": "./toasts/index.d.ts",
			"default": "./dist/toasts.js"
		},
		"./browser": {
			"types": "./browser/index.d.ts",
			"default": "./dist/browser.js"
		},
		"./proto": {
			"types": "./proto/index.d.ts",
			"default": "./dist/proto.js"
		},
		"./behaviors": {
			"types": "./behaviors/index.d.ts",
			"default": "./dist/behaviors.js"
		},
		"./utils": {
			"types": "./utils/index.d.ts",
			"default": "./dist/utils.js"
		},
		"./behaviors/*": {
			"types": "./behaviors/*.d.ts",
			"default": "./dist/behaviors/*.js"
		},
		"./utils/*": {
			"types": "./utils/*.d.ts",
			"default": "./dist/utils/*.js"
		},
		"./qrp.css": "./qrp.css",
		"./package.json": "./package.json"
	},
	"author": "Nemanja Nedeljkovic <nemanjan00@gmail.com>",
	"homepage": "https://qrp-xdl4.onrender.com/",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nemanjan00/qrp.git"
	},
	"bugs": {
		"url": "https://github.com/nemanjan00/qrp/issues"
	},
	"keywords": [
		"dashboard",
		"reactive",
		"proxy",
		"declarative",
		"framework",
		"frontend",
		"no-build",
		"zero-dependency",
		"dom",
		"forms",
		"table"
	],
	"scripts": {
		"test": "node --test 'test/*.test.js'",
		"build": "node bin/build.js",
		"lint": "eslint qrp forms browser events toasts proto http utils behaviors collection table html test",
		"prepack": "node bin/build.js",
		"prepare": "husky",
		"typecheck": "tsc --noEmit",
		"docs": "node bin/gen-api.js"
	},
	"files": [
		"dist",
		"*/index.d.ts",
		"behaviors/*.d.ts",
		"utils/*.d.ts",
		"qrp.css"
	],
	"publishConfig": {
		"access": "public"
	},
	"lint-staged": {
		"*.js": "eslint --fix"
	},
	"devDependencies": {
		"@babel/core": "^7.29.7",
		"@babel/eslint-parser": "^7.29.7",
		"esbuild": "^0.28.1",
		"eslint": "^8.57.1",
		"happy-dom": "^15.11.7",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"typescript": "^7.0.2"
	},
	"types": "./qrp/index.d.ts"
}
